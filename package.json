{
  "name": "agent-daemon",
  "packageManager": "pnpm@10.8.1",
  "version": "0.1.0",
  "description": "Local daemon that listens to Linear webhooks and orchestrates AI agents via Temporal",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:worker": "tsx watch src/temporal/worker.ts",
    "dev:temporal": "temporal server start-dev --db-filename temporal.db",
    "dev": "concurrently \"npm run dev:temporal\" \"npm run dev:server\" \"npm run dev:worker\"",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.1",
    "@linear/sdk": "^29.0.0",
    "@temporalio/activity": "^1.11.7",
    "@temporalio/client": "^1.11.7",
    "@temporalio/worker": "^1.11.7",
    "@temporalio/workflow": "^1.11.7",
    "dotenv": "^17.3.1",
    "hono": "^4.7.6",
    "yaml": "^2.7.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
