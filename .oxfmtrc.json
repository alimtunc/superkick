{
	"$schema": "./ui/node_modules/oxfmt/configuration_schema.json",
	"singleQuote": true,
	"semi": false,
	"trailingComma": "none",
	"useTabs": true,
	"tabWidth": 4,
	"printWidth": 110,
	"sortImports": {
		"newlinesBetween": true,
		"groups": [
			"react",
			"builtin",
			"external",
			"internal",
			["parent", "sibling", "index"],
			"style",
			"unknown"
		],
		"customGroups": [
			{
				"groupName": "react",
				"elementNamePattern": ["react", "react-dom", "react-dom/**", "react-*"]
			}
		],
		"internalPattern": ["@superkick/", "~/"]
	},
	"sortTailwindcss": {
		"stylesheet": "./ui/src/index.css",
		"functions": ["cn", "cva"]
	}
}
