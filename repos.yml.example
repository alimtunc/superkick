# Map Linear team keys to git repositories.
# The daemon uses this to know which repo to clone when an issue comes in.
#
# To find your team key: Linear → Settings → Teams → look at the prefix (e.g., "ENG-123" → key is "ENG")

teams:
  ENG:
    repo: git@github.com:user/app.git
  # DESIGN:
  #   repo: git@github.com:user/design-system.git
