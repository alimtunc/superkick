# Place this file at the root of any repo you want the agent to work on.

repo: git@github.com:user/project.git
base_branch: main
test_command: npm run test
lint_command: npm run lint
max_retries: 2

# Which LLM to use by default (can be overridden via Linear label "agent:codex")
default_agent: claude
command: claude --dangerously-skip-permissions

# Project context — the agent reads this before starting
context: |
  Describe your project here: stack, conventions, important patterns.
  The agent will use this as initial context for every task.
